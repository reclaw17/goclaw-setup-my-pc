# Copy to .env and fill in. Never commit real .env

# --- GoClaw local ---
GOCLAW_HOST=127.0.0.1
# GOCLAW_GATEWAY_TOKEN=   # auto-filled on first start if empty
# GOCLAW_ENCRYPTION_KEY=  # auto-filled on first start if empty

# --- Cloud (primary) — paste keys without quotes ---
XAI_API_KEY=
# OPENROUTER_API_KEY=
# QWEN_API_KEY=
# MINIMAX_API_KEY=

# Optional OpenAI-compatible local (Fabric) when online is down:
# LOCAL_LLM_BASE_URL=http://127.0.0.1:8080/v1
# LOCAL_LLM_API_KEY=sk-local

# Legacy / optional (Standard edition only — NOT required for Lite AppImage)
# GOCLAW_POSTGRES_DSN=
