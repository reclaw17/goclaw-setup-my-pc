# Скопируй в .env (подготовить.sh / старт.sh могут создать сами)

# --- Обязательные для GoClaw Standard ---
# Генерируются автоматически при старте, если пустые
GOCLAW_GATEWAY_TOKEN=
GOCLAW_ENCRYPTION_KEY=

# Локальный безопасный bind (НЕ 0.0.0.0)
GOCLAW_HOST=127.0.0.1

# Только для чисто локальной отладки, если токена нет:
# GOCLAW_ALLOW_INSECURE_NO_AUTH=1

# PostgreSQL (нужен для GoClaw Standard)
# Пример:
# GOCLAW_POSTGRES_DSN=postgres://goclaw:PASSWORD@127.0.0.1:5432/goclaw?sslmode=disable
GOCLAW_POSTGRES_DSN=

# --- Облачные ключи (online-режим) ---
# Имена зависят от провайдера в GoClaw dashboard / docs
# GOCLAW_OPENAI_API_KEY=
# GOCLAW_OPENROUTER_API_KEY=
# GROK_API_KEY=
# QWEN_API_KEY=
# MINIMAX_API_KEY=
