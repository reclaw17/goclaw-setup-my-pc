# =============================================================================
# Copy to .env ON THE USB STICK and fill in real keys.
#   cp -n .env.example .env
# Never commit .env to git. .gitignore already blocks it.
# =============================================================================

# --- GoClaw local ---
GOCLAW_HOST=127.0.0.1
# GOCLAW_GATEWAY_TOKEN=
# GOCLAW_ENCRYPTION_KEY=

# --- Cloud LLMs (primary when online) — no quotes ---
XAI_API_KEY=
OPENROUTER_API_KEY=
QWEN_API_KEY=
MINIMAX_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# --- Web research (Perplexity / Sonar) ---
PERPLEXITY_API_KEY=
# Alias used by some skills:
# PERPLEX_API_KEY=

# --- Optional OpenAI-compatible local (Fabric) offline ---
LOCAL_LLM_BASE_URL=http://127.0.0.1:8080/v1
LOCAL_LLM_API_KEY=sk-local

# --- Paths on USB (optional overrides) ---
# GOCLAW_USB_ROOT=
# GOCLAW_DOCS_ROOT=docs
# GOCLAW_DOCS_MIRRORS=docs/mirrors

# Legacy Standard edition only (NOT needed for Lite AppImage):
# GOCLAW_POSTGRES_DSN=
